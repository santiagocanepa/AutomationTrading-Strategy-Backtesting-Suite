# SuiteTrading v2 — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env with secrets.

# Exchange API (Sprint 1+)
# BINANCE_API_KEY=
# BINANCE_API_SECRET=

# Data paths
DATA_DIR=./data
RESULTS_DIR=./results

# Logging
LOG_LEVEL=INFO
# FRED (Federal Reserve Economic Data) — for macro indicators
FRED_API_KEY=your_fred_api_key_here  